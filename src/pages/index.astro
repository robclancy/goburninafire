---
import Layout from '../layouts/Layout.astro';
import FireOverlay from '../components/FireOverlay.astro';
---

<style>
.burn {
	position: relative;
	width: 100%;
	height: 100vh;
	background: #040404;
}

.fire {
	position: fixed;
	inset: 0;
}
</style>

<Layout>
	<div class="burn">
		<div class="fire">
			<FireOverlay />
		</div>
	</div>
</Layout>