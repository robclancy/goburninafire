<style>
#fire-video { display: none }

#fire-canvas {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  min-width: 100%;
  min-height: 100%;
  width: auto;
  height: auto;
  pointer-events: none;
  object-fit: cover;
}
</style>

<video id="fire-video" src="/fire2.mp4" loop muted playsinline></video>
<canvas id="fire-canvas"></canvas>

<script>
import GLChroma from 'gl-chromakey'

const video = document.getElementById("fire-video")
const canvas = document.getElementById("fire-canvas")

const chroma = new GLChroma(video, canvas)
chroma.key({
	color: 'auto',
	tolerance: 0.3,
	smoothness: 0.3,
	spill: 0,
})

let frameId

// methods for render loop
const startChroma = () => {
  frameId = requestAnimationFrame(startChroma)
  chroma.render()
}
const stopChroma = () => cancelAnimationFrame(frameId)

// follow <video> element events
video.addEventListener('play', startChroma)
video.addEventListener('pause', stopChroma)
video.addEventListener('ended', stopChroma)

let started = false
